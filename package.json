{
  "name": "pixelbox",
  "productName": "Pixelbox",
  "version": "0.3.0",
  "description": "Pixelbox native shell with built-in code editor and terminal",
  "main": "bridge/server.js",
  "scripts": {
    "dev": "zig build run",
    "dev:backend": "node bridge/server.js",
    "dev:hot": "zig build dev",
    "icon:mac": "bash scripts/make-mac-icon.sh",
    "build": "zig build",
    "build:mac": "zig build package -Dpackage-target=macos",
    "start": "zig build run",
    "test": "node --test",
    "test:codex": "RUN_CODEX_E2E=1 node --test test/terminal.codex.e2e.test.js",
    "test:pw:visual-loop": "PW_VISUAL_LOOP_VIDEO=1 node test/pw_visual_loop_video.js",
    "test:pw:visual-loop:codex": "PW_VISUAL_LOOP_VIDEO=1 PW_VISUAL_LOOP_REAL_CODEX=1 node test/pw_visual_loop_video.js"
  },
  "dependencies": {
    "monaco-editor": "^0.52.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "zero-native": "^0.1.9"
  }
}
